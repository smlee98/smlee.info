{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "description": "smlee.info — Fullstack Developer 이승민의 포트폴리오",
  "homepage": "https://smlee.info",
  "scripts": {
    "dev": "next dev",
    "build": "yarn registry:build && next build",
    "start": "next start",
    "registry:build": "tsx ./src/scripts/build-registry.mts && shadcn build",
    "registry:validate": "shadcn registry validate ./public/r/registry.json",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint --fix . --cache --cache-location .eslintcache",
    "check-types": "tsc --noEmit --pretty",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,md,mdx}\" --cache",
    "prepare": "husky",
    "precommit": "lint-staged",
    "prepush": "yarn check-types && yarn lint && yarn test:run",
    "generate-libphonenumber-metadata": "yarn dlx libphonenumber-metadata-generator ./src/assets/libphonenumber.metadata.json --countries KR --extended"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@bprogress/next": "^3.2.12",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@phosphor-icons/react": "^2.1.10",
    "@react-pdf/renderer": "^4.5.1",
    "@remixicon/react": "^4.9.0",
    "@rexa-developer/tiks": "^0.1.9",
    "@tabler/icons-react": "^3.42.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "fumadocs-core": "^16.10.5",
    "fumadocs-typescript": "^5.2.6",
    "gray-matter": "^4.0.3",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "jotai": "^2.18.1",
    "libphonenumber-js": "^1.12.4",
    "lru-cache": "^11.2.6",
    "lucide-react": "^1.14.0",
    "motion": "^12.39.0",
    "next": "16.2.9",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hotkeys-hook": "^5.3.2",
    "react-markdown": "^10.1.0",
    "react-medium-image-zoom": "^5.4.0",
    "react-resizable-panels": "^4.9.0",
    "react-use": "^17.6.0",
    "schema-dts": "^1.1.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "web-haptics": "^0.0.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.19",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/hast": "^3.0.4",
    "@types/node": "^20.14.12",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.22.0",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rehype-external-links": "^3.0.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.0",
    "rimraf": "^6.0.1",
    "shadcn": "4.12.0",
    "shiki": "^4.3.1",
    "strip-indent": "^4.0.0",
    "tailwindcss": "^4.3.1",
    "ts-morph": "^26.0.0",
    "tsx": "^4.20.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.8.3",
    "unist-builder": "3.0.0",
    "unist-util-visit": "^5.0.0",
    "vitest": "^4.1.8"
  },
  "resolutions": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  },
  "engines": {
    "node": ">=22.x"
  },
  "packageManager": "yarn@4.12.0"
